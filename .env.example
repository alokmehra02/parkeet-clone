# ─────────────────────────────────────────────────────────────
# MeetAssist — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Values set here override ~/.meetassist/config.json.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ── Optional — AI / Transcription ─────────────────────────────
# GPT model to use for answers
# MEETASSIST_MODEL=gpt-4o

# Transcription backend: "whisper-api" (cloud) | "faster-whisper" (local)
# MEETASSIST_ENGINE=whisper-api

# ── Optional — Overlay Appearance ─────────────────────────────
# Window transparency: 0.0 (invisible) to 1.0 (opaque)
# MEETASSIST_OPACITY=0.92

# Font size in the overlay panel (pixels)
# MEETASSIST_FONT_SIZE=14

# ── Optional — Hotkeys ─────────────────────────────────────────
# Override default global hotkey combinations
# MEETASSIST_HOTKEY_TOGGLE=ctrl+shift+h
# MEETASSIST_HOTKEY_ASK=ctrl+shift+a
# MEETASSIST_HOTKEY_CLEAR=ctrl+shift+c
# MEETASSIST_HOTKEY_QUIT=ctrl+shift+q
